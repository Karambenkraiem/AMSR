generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  charge_travaux
  charge_consignation
  charge_exploitation
  chef_centrale
  chef_maintenance
  directeur
  animateur_securite
  responsable_securite
  guest
}

enum RegimeType {
  consignation
  exceptionnel_travaux
  essais
  requisition
  interventions
}

enum TypeBon {
  travail
  visite_systematique
}

enum StatutDemande {
  soumise
  en_cours_attestation
  accord_exploitation
  regime_execute
  attente_confirmation_assistant
  en_cours
  arret_temporaire
  operation_terminee
  cloturee
  rejetee
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  email     String   @unique
  password  String
  matricule String   @unique
  role      Role
  centrale  String   @default("Centrale Goulette 2")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  demandesChargeTravaux       Demande[]       @relation("ChargeTravaux")
  demandesAssistant           Demande[]       @relation("AssistantCT")
  accordExploitation          Attestation[]   @relation("AccordExploitation")
  regimeExecuteConsignation   Attestation[]   @relation("RegimeExecute")
  regimeDelivreTravaux        Attestation[]   @relation("RegimeDelivre")
  assistantDelivreAtts        Attestation[]   @relation("AssistantDelivre")
  operationTermineeTravaux    Attestation[]   @relation("OperationTerminee")
  regimeLeveTravaux           Attestation[]   @relation("RegimeLeve")
  notifications               Notification[]
  changements                 ChangementCharge[] @relation("Remplace")
  delegationsAccordees        Delegation[]       @relation("Delegant")
  delegationsRecues           Delegation[]       @relation("Delegue")
  commentairesSecurite        CommentaireSecurite[]
}

model Demande {
  id                        Int           @id @default(autoincrement())
  numero                    String        @unique
  centrale                  String

  designationOperation      String
  tr                        String?
  tg                        String?
  niveau                    String?
  ouvragesConcernes         String?

  datePrevu                 DateTime?
  dureePrevu                String?
  instructionsParticulieres String?

  typeBon                   TypeBon?
  numeroBon                 String?
  regimeType                RegimeType

  serviceDemandeur          String?
  assistantNom              String?
  assistantChargeTravaux    User?         @relation("AssistantCT", fields: [assistantChargeTravauxId], references: [id])
  assistantChargeTravauxId  Int?

  permisFeu                 Boolean       @default(false)
  permisControle            Boolean       @default(false)
  permisAcces               Boolean       @default(false)
  permisRadiographique      Boolean       @default(false)
  permisFouille             Boolean       @default(false)

  status                    StatutDemande @default(soumise)

  chargeTravaux             User          @relation("ChargeTravaux", fields: [chargeTravauxId], references: [id])
  chargeTravauxId           Int

  attestation               Attestation?
  notifications             Notification[]
  commentairesSecurite      CommentaireSecurite[]

  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
}

model Attestation {
  id        Int    @id @default(autoincrement())
  numero    String @unique

  demande   Demande @relation(fields: [demandeId], references: [id])
  demandeId Int     @unique

  codeBdm              String?
  ouvrageDesignation   String?
  local                String?
  repere               String?
  manoeuvresCondamnation String?
  instructions         Json?

  permisFeu            Boolean @default(false)
  permisFouille        Boolean @default(false)
  permisControleRadio  Boolean @default(false)
  permisAcces          Boolean @default(false)

  accordExploitation   User?   @relation("AccordExploitation", fields: [accordExploitationId], references: [id])
  accordExploitationId Int?
  accordDate           DateTime?

  regimeExecute        User?   @relation("RegimeExecute", fields: [regimeExecuteId], references: [id])
  regimeExecuteId      Int?
  regimeExecuteDate    DateTime?

  regimeDelivre        User?   @relation("RegimeDelivre", fields: [regimeDelivreId], references: [id])
  regimeDelivreId      Int?
  regimeDelivreDate    DateTime?
  assistantDelivre     User?   @relation("AssistantDelivre", fields: [assistantDelivreId], references: [id])
  assistantDelivreId   Int?
  assistantDelivreNom  String?

  operationTerminee    User?   @relation("OperationTerminee", fields: [operationTermineeId], references: [id])
  operationTermineeId  Int?
  operationTermineeDate DateTime?
  assistantTermineeNom String?

  regimeLeve           User?   @relation("RegimeLeve", fields: [regimeleveId], references: [id])
  regimeleveId         Int?
  regimeleveDate       DateTime?

  status               StatutDemande @default(soumise)

  changements          ChangementCharge[]
  interruptions        Interruption[]
  commentairesSecurite CommentaireSecurite[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ChangementCharge {
  id            Int         @id @default(autoincrement())
  attestation   Attestation @relation(fields: [attestationId], references: [id])
  attestationId Int
  typeRole      String
  remplacantNom String
  remplacantPrenom String?
  dateEffet     DateTime
  remplace      User        @relation("Remplace", fields: [remplacerId], references: [id])
  remplacerId   Int
  createdAt     DateTime    @default(now())
}

model Interruption {
  id            Int         @id @default(autoincrement())
  attestation   Attestation @relation(fields: [attestationId], references: [id])
  attestationId Int

  ouvrageDisponible Boolean @default(false)
  dateArret         DateTime?
  heureArret        String?
  chargeTravauxArretNom        String?
  chargeConsignationArret1Nom  String?
  chargeConsignationArret2Nom  String?

  etatRegime   String    @default("suspendu")

  dateReprise  DateTime?
  heureReprise String?
  chargeTravauxRepriseNom       String?
  chargeConsignationReprise1Nom String?
  chargeConsignationReprise2Nom String?

  nomVisas     String?
  createdAt    DateTime  @default(now())
}

model Delegation {
  id         Int      @id @default(autoincrement())
  delegant   User     @relation("Delegant", fields: [delegantId], references: [id])
  delegantId Int
  delegue    User     @relation("Delegue", fields: [delegueId], references: [id])
  delegueId  Int
  role       String
  dateDebut  DateTime
  dateFin    DateTime
  active     Boolean  @default(true)
  note       String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  message   String
  type      String
  read      Boolean  @default(false)
  demande   Demande? @relation(fields: [demandeId], references: [id])
  demandeId Int?
  createdAt DateTime @default(now())
}

// Commentaires internes de l'animateur sécurité — jamais inclus dans les documents imprimés
model CommentaireSecurite {
  id            Int          @id @default(autoincrement())
  demande       Demande?     @relation(fields: [demandeId], references: [id])
  demandeId     Int?
  attestation   Attestation? @relation(fields: [attestationId], references: [id])
  attestationId Int?
  auteur        User         @relation(fields: [auteurId], references: [id])
  auteurId      Int
  contenu       String
  createdAt     DateTime     @default(now())
}

// Ligne unique (id=1) — paramètres globaux de l'application
model AppConfig {
  id              Int     @id @default(1)
  demoModeEnabled Boolean @default(true)
  updatedAt       DateTime @updatedAt
}
